# Copy to .env for local development (never commit .env)

# Flask
SECRET_KEY=replace-with-a-long-random-secret-key
FLASK_DEBUG=1

# MongoDB Atlas (required for production)
# Create free cluster at https://cloud.mongodb.com
# Database Access → user/password → Network Access → Allow 0.0.0.0/0 (for Vercel)
MONGO_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=agrosmart_ai

# For production, set FLASK_ENV=production and SECRET_KEY in Vercel environment variables
